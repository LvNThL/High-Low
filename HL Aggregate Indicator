getThemeColors(string theme) =>
    switch theme
        "Neon"            => [#00ff80, #af00ff, color.new(#ffffff, 30)]
        "Azure Trade"     => [#0EA5E9, #F97316, color.new(#BDE0FE, 30)]
        "Sage & Clay"     => [#6BA82E, #D97706, color.new(#D7E5B4, 30)]
        "Slate Pro"       => [#3B82F6, #EF4444, color.new(#DBEAFE, 30)]
        "Twilight Modern" => [#8B5CF6, #06B6D4, color.new(#E9D5FF, 30)]
        => [#64748B, #1E293B, color.new(#CBD5E1, 30)]

[maBullColor, maBearColor, maMidColor] = getThemeColors(colorTheme)
[bbBullColor, bbBearColor, bbMidColor] = getThemeColors(colorTheme)
[regrBullColor, regrBearColor, regrMidColor] = getThemeColors(colorTheme)

safeLog(float value) =>
    math.log(math.max(value, 1e-15))

safeExp(float value) =>
    math.exp(math.min(value, 100.0))

isBullish(float median) =>
    open > median

getPlotColor(float median) =>
    isBullish(median) ? maBullColor : maBearColor

getBBPlotColor(float median) =>
    isBullish(median) ? bbBullColor : bbBearColor

thinLineWidth = math.max(lineThickness - 1, 1)

// ═══════════════════════════════════════════════════════════════════════
// 3. MOVING AVERAGE CALCULATIONS
// ═══════════════════════════════════════════════════════════════════════
maCalc(float source, int length, string method) =>
    switch method
        "SMA"   => ta.sma(source, length)
        "EMA"   => ta.ema(source, length)
        "RMA"   => ta.rma(source, length)
        "VWMA"  => ta.vwma(source, length)
        "DEMA"  => ta.dema(source, length)
        "TEMA"  => ta.tema(source, length)
        "FRAMA" => ta.frama(source, length)
        "HMA"   => ta.hma(source, length)
        "WMA"   => ta.wma(source, length)

medianMA(int period) =>
    float avgHigh = ta.sma(high, period + 1)
    float avgLow  = ta.sma(low, period + 1)
    maCalc(math.avg(avgHigh, avgLow), period, maType)

float median1  = medianMA(lookback1)
float median2  = medianMA(lookback2)
float median3  = medianMA(lookback3)
float median4  = medianMA(lookback4)
float median5  = medianMA(lookback5)
float median6  = medianMA(lookback6)
float median7  = medianMA(lookback7)
float median8  = medianMA(lookback8)
float median9  = medianMA(lookback9)
float median10 = medianMA(lookback10)
float median11 = medianMA(lookback11)

float bollingerDeviation = useLogBollinger ? ta.stdev(safeLog(close), lookback11) : ta.stdev(close, lookback11)
float bollingerUpper = useLogBollinger ? safeExp(safeLog(median11) + bollingerStdDev * bollingerDeviation) : median11 + bollingerStdDev * bollingerDeviation
float bollingerLower = useLogBollinger ? safeExp(safeLog(median11) - bollingerStdDev * bollingerDeviation) : median11 - bollingerStdDev * bollingerDeviation

// ═══════════════════════════════════════════════════════════════════════
// 4. REGRESSION & STATISTICS
// ═══════════════════════════════════════════════════════════════════════
approximateErf(float x) =>
    float sign = x < 0 ? -1.0 : 1.0
    float absX = math.abs(x)
    float t = 1.0 / (1.0 + 0.3275911 * absX)
    float polynomial = (((((1.061405429 * t - 1.453152027) * t) + 1.421413741) * t - 0.284496736) * t + 0.254829592)
    float y = 1.0 - polynomial * t * math.exp(math.max(-100.0, -absX * absX))
    sign * y

calculateVisibleRegression(int leftBar, int rightBar, bool logScaleMode) =>
    int length = rightBar - leftBar + 1
    int barsToRight = bar_index - rightBar

    float slope = 0.0
    float upperIntercept = close
    float lowerIntercept = close
    float medianIntercept = close
    float rSquaredPercent = 0.0
    float pValue = 1.0

    if length > 1
        float sumX = 0.0
        float sumY = 0.0
        float sumXY = 0.0
        float sumX2 = 0.0
        float sumY2 = 0.0

        for i = 0 to length - 1
            int barOffset = math.max(0, barsToRight + i)
            float rawY = close[barOffset]
            float y = logScaleMode ? safeLog(rawY) : rawY
            float x = float(length - 1 - i)

            sumX  += x
            sumY  += y
            sumXY += x * y
            sumX2 += x * x
            sumY2 += y * y

        float denomX = (length * sumX2) - (sumX * sumX)
        float denomY = (length * sumY2) - (sumY * sumY)

        slope := denomX > 0 ? ((length * sumXY) - (sumX * sumY)) / denomX : 0.0
        medianIntercept := length > 0 ? (sumY - slope * sumX) / length : 0.0

        float correlation = (denomX > 0 and denomY > 0) ? ((length * sumXY) - (sumX * sumY)) / math.sqrt(denomX * denomY) : 0.0
        rSquaredPercent := (correlation * correlation) * 100.0

        if length > 2 and (correlation * correlation) < 0.999999
            float tStat = math.abs(correlation) * math.sqrt(math.max(0.0, (length - 2) / math.max(1e-10, 1.0 - (correlation * correlation))))
            pValue := 1.0 - approximateErf(tStat / 1.41421356237)
        else if (correlation * correlation) >= 0.999999
            pValue := 0.0

        upperIntercept := medianIntercept
        lowerIntercept := medianIntercept

        for i = 0 to length - 1
            int barOffset = math.max(0, barsToRight + i)
            float x = float(length - 1 - i)

            float highValue = logScaleMode ? safeLog(high[barOffset]) : high[barOffset]
            float lowValue  = logScaleMode ? safeLog(low[barOffset])  : low[barOffset]

            float highIntercept = highValue - slope * x
            float lowIntercept  = lowValue  - slope * x

            upperIntercept := highIntercept > upperIntercept ? highIntercept : upperIntercept
            lowerIntercept := lowIntercept < lowerIntercept ? lowIntercept : lowerIntercept

    [slope, upperIntercept, lowerIntercept, medianIntercept, rSquaredPercent, pValue]

// ═══════════════════════════════════════════════════════════════════════
// 5. VISIBLE RANGE TRACKING & MAPPING
// ═══════════════════════════════════════════════════════════════════════

// Arrays to map Time to Bar Index instantly
var array<int> timeArr = array.new_int()
var array<int> indexArr = array.new_int()

// Populate arrays exactly once per bar to maintain the map
if barstate.islast == false or barstate.isnew
    array.push(timeArr, time)
    array.push(indexArr, bar_index)
    
    // Cap the array size at 20,000 bars to manage memory efficiently
    if array.size(timeArr) > 20000 
        array.shift(timeArr)
        array.shift(indexArr)

// Binary search method for O(log N) lookup speed on the last bar
method get_index_by_time(array<int> times, array<int> indices, int targetTime) =>
    int left = 0
    int right = array.size(times) - 1
    int bestIdx = na
    
    while left <= right
        int mid = math.floor((left + right) / 2)
        int midTime = array.get(times, mid)
        
        if midTime == targetTime
            bestIdx := array.get(indices, mid)
            break
        else if midTime < targetTime
            bestIdx := array.get(indices, mid) // Track closest smaller time in case of gaps
            left := mid + 1
        else
            right := mid - 1
    bestIdx

// Lines declared once using 'var'
var line visibleHighLine = line.new(na, na, na, na, xloc=xloc.bar_index, extend=extend.right, style=line.style_dashed, width=1)
var line visibleLowLine  = line.new(na, na, na, na, xloc=xloc.bar_index, extend=extend.right, style=line.style_dashed, width=1)

var line liveTrendHigh = line.new(na, na, na, na, style=line.style_solid)
var line liveTrendLow = line.new(na, na, na, na, style=line.style_solid)
var line liveTrendMiddle = line.new(na, na, na, na, style=line.style_dashed)

var table statsTable = table.new(
    position.bottom_right,
    2,
    3,
    bgcolor=color.new(color.black, 20),
    frame_color=color.new(color.gray, 50),
    frame_width=1,
    border_color=color.new(color.gray, 80),
    border_width=1
)

// ═══════════════════════════════════════════════════════════════════════
// 6. PLOTTING & REAL-TIME UPDATES
// ═══════════════════════════════════════════════════════════════════════

plot(median1,  color=getPlotColor(median1),  linewidth=thinLineWidth,  title="MA 1", display = _showMAS ? display.all : display.none)
plot(median2,  color=getPlotColor(median2),  linewidth=thinLineWidth,  title="MA 2", display = _showMAS ? display.all : display.none)
plot(simplifiedMAs ? na : median3,  color=getPlotColor(median3),  linewidth=thinLineWidth,  title="MA 3", display = _showMAS ? display.all : display.none)
plot(simplifiedMAs ? na : median4,  color=getPlotColor(median4),  linewidth=thinLineWidth,  title="MA 4", display = _showMAS ? display.all : display.none)
plot(median5,  color=getPlotColor(median5),  linewidth=lineThickness,  title="MA 5", display = _showMAS ? display.all : display.none)
plot(simplifiedMAs ? na : median6,  color=getPlotColor(median6),  linewidth=thinLineWidth,  title="MA 6", display = _showMAS ? display.all : display.none)
plot(simplifiedMAs ? na : median7,  color=getPlotColor(median7),  linewidth=thinLineWidth,  title="MA 7", display = _showMAS ? display.all : display.none)
plot(simplifiedMAs ? na : median8,  color=getPlotColor(median8),  linewidth=thinLineWidth,  title="MA 8", display = _showMAS ? display.all : display.none)
plot(simplifiedMAs ? na : median9,  color=getPlotColor(median9),  linewidth=thinLineWidth,  title="MA 9", display = _showMAS ? display.all : display.none)
plot(simplifiedMAs ? na : median10, color=getPlotColor(median10), linewidth=thinLineWidth,  title="MA 10", display = _showMAS ? display.all : display.none)
plot(median11, color=getBBPlotColor(median11), linewidth=lineThickness,  title="MA 11", display = _showMAS ? display.all : display.none)

// Bollinger Bands without the background fill
plot(bollingerLower, "BB Lower", color=bbBullColor, display=showBollingerBands ? display.all : display.none, linewidth=lineThickness)
plot(bollingerUpper, "BB Upper", color=bbBearColor, display=showBollingerBands ? display.all : display.none, linewidth=lineThickness)

// EXECUTED ONLY ON LAST BAR (To respond instantly to chart panning)
if barstate.islast
    int calcStartX = na
    int calcEndX = na

    if lrcCalcMode == "Visible Range"
        // Instant array mapping vs slow history looping
        calcStartX := timeArr.get_index_by_time(indexArr, chart.left_visible_bar_time)
        calcEndX   := timeArr.get_index_by_time(indexArr, chart.right_visible_bar_time)
    else
        calcStartX := math.max(0, bar_index - lrcFixedLength + 1)
        calcEndX := bar_index

    // DYNAMIC VISIBLE HIGH/LOW TRACKING
    if showVisibleHL and not na(calcStartX) and not na(calcEndX)
        float visHigh = na
        float visLow = na
        int visHighBar = na
        int visLowBar = na
        
        int barsToStart = bar_index - calcStartX
        int barsToEnd = bar_index - calcEndX
        
        // Scan backwards through visible bars 
        for i = math.max(0, barsToEnd) to math.max(0, barsToStart)
            float h = high[i]
            float l = low[i]
            int bIdx = bar_index - i
            
            if na(visHigh) or h > visHigh
                visHigh := h
                visHighBar := bIdx
            if na(visLow) or l < visLow
                visLow := l
                visLowBar := bIdx
                
        if not na(visHigh)
            line.set_xy1(visibleHighLine, visHighBar, visHigh)
            line.set_xy2(visibleHighLine, visHighBar + 1, visHigh)
            line.set_color(visibleHighLine, maBullColor)
            
            line.set_xy1(visibleLowLine, visLowBar, visLow)
            line.set_xy2(visibleLowLine, visLowBar + 1, visLow)
            line.set_color(visibleLowLine, maBearColor)

    // LINEAR REGRESSION UPDATES
    if not na(calcStartX) and not na(calcEndX)
        [slope, upperIntercept, lowerIntercept, medianIntercept, strength, pValue] = calculateVisibleRegression(calcStartX, calcEndX, useLogScale)

        int startX = calcStartX
        int endX = calcEndX + futureExtension

        float startYHigh = upperIntercept
        float endYHigh   = slope * (endX - startX) + upperIntercept

        float startYLow  = lowerIntercept
        float endYLow    = slope * (endX - startX) + lowerIntercept

        float startYMid  = medianIntercept
        float endYMid    = slope * (endX - startX) + medianIntercept

        if useLogScale
            startYHigh := safeExp(startYHigh)
            endYHigh   := safeExp(endYHigh)
            startYLow  := safeExp(startYLow)
            endYLow    := safeExp(endYLow)
            startYMid  := safeExp(startYMid)
            endYMid    := safeExp(endYMid)

        if showLRC
            line.set_xy1(liveTrendHigh, startX, startYHigh)
            line.set_xy2(liveTrendHigh, endX, endYHigh)
            line.set_color(liveTrendHigh, regrBearColor)
            line.set_width(liveTrendHigh, lineThickness)
            
            line.set_xy1(liveTrendLow, startX, startYLow)
            line.set_xy2(liveTrendLow, endX, endYLow)
            line.set_color(liveTrendLow, regrBullColor)
            line.set_width(liveTrendLow, lineThickness)
            
            line.set_xy1(liveTrendMiddle, startX, startYMid)
            line.set_xy2(liveTrendMiddle, endX, endYMid)
            line.set_color(liveTrendMiddle, regrMidColor)
            line.set_width(liveTrendMiddle, 1)

        if showHUD
            color strengthColor = strength >= 75 ? #00ff00 : strength >= 50 ? #ffff00 : #ff0000
            table.cell(statsTable, 0, 0, "Trend Power (R²):", text_color=color.white, text_size=size.small, text_halign=text.align_left)
            table.cell(statsTable, 1, 0, str.tostring(strength, "#.##") + "%", text_color=strengthColor, text_size=size.small, text_halign=text.align_right)

            color pValueColor = pValue <= 0.01 ? #00ff00 : pValue <= 0.05 ? #ffff00 : #ff0000
            string pValueText = pValue < 0.001 ? "< 0.001" : str.tostring(pValue, "#.###")
            table.cell(statsTable, 0, 1, "P-Value:", text_color=color.white, text_size=size.small, text_halign=text.align_left)
            table.cell(statsTable, 1, 1, pValueText, text_color=pValueColor, text_size=size.small, text_halign=text.align_right)

            float channelWidthPct = ((startYHigh - startYLow) / math.max(startYMid, 1e-15)) * 100.0
            table.cell(statsTable, 0, 2, "Channel Width:", text_color=color.white, text_size=size.small, text_halign=text.align_left)
            table.cell(statsTable, 1, 2, str.tostring(channelWidthPct, "#.##") + "%", text_color=color.white, text_size=size.small, text_halign=text.align_right)
